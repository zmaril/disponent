{
  "name": "@disponent/node",
  "version": "0.0.0",
  "description": "Dispatch work to coding agents — the disponent engine as an in-process Node/Bun native addon.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "disponent"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release --no-const-enum --runtime-string-enum",
    "build:debug": "napi build --platform --no-const-enum --runtime-string-enum",
    "gen": "bash ../../scripts/gen.sh",
    "check": "biome check .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@napi-rs/cli": "^3.4.2"
  }
}
